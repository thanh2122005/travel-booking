generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum TourStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
}

model User {
  id           String     @id @default(cuid())
  fullName     String
  email        String     @unique
  passwordHash String
  avatarUrl    String?
  phone        String?
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([role])
  @@index([status])
}

model Location {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  provinceOrCity   String
  country          String
  shortDescription String
  description      String
  imageUrl         String
  gallery          String[]
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tours Tour[]

  @@index([featured])
}

model Tour {
  id                String     @id @default(cuid())
  title             String
  slug              String     @unique
  shortDescription  String
  description       String
  price             Int
  discountPrice     Int?
  durationDays      Int
  durationNights    Int
  maxGuests         Int
  transportation    String
  departureLocation String
  featuredImage     String
  status            TourStatus @default(ACTIVE)
  featured          Boolean    @default(false)
  locationId        String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  location    Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  images      TourImage[]
  itineraries Itinerary[]
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  contactInquiries ContactInquiry[]

  @@index([locationId])
  @@index([status])
  @@index([featured])
  @@index([price])
}

model TourImage {
  id        String @id @default(cuid())
  tourId    String
  imageUrl  String
  sortOrder Int    @default(0)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model Itinerary {
  id          String @id @default(cuid())
  tourId      String
  dayNumber   Int
  title       String
  description String

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber])
  @@index([tourId])
}

model Booking {
  id             String        @id @default(cuid())
  bookingCode    String        @unique
  userId         String
  tourId         String
  fullName       String
  email          String
  phone          String
  numberOfGuests Int
  note           String?
  totalPrice     Int
  status         BookingStatus @default(PENDING)
  paymentMethod  String        @default("Thanh toan khi xac nhan")
  paymentStatus  PaymentStatus @default(UNPAID)
  departureDate  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tourId])
  @@index([status])
  @@index([paymentStatus])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  tourId    String
  rating    Int
  comment   String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@index([tourId])
  @@index([isVisible])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  tourId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@index([userId])
  @@index([tourId])
}

model ContactInquiry {
  id             String    @id @default(cuid())
  referenceCode  String    @unique
  fullName       String
  phone          String
  email          String
  tourId         String?
  departureDate  DateTime?
  numberOfGuests Int
  message        String
  status         InquiryStatus @default(PENDING)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tour Tour? @relation(fields: [tourId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([email])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

enum InquiryStatus {
  PENDING
  RESOLVED
}
